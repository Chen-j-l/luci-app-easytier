
config easytier
	option enabled '0'
	option etcmd 'etcmd'
	option instance_name 'default'
	option dhcp '1'
	option network_name 'network_name'
	option network_secret 'network_secret'
	option rpc_portal '15888'
	option default_protocol '-'
	option dev_name 'easytier0'
	option encryption_algorithm 'aes-gcm'
	option data_compress_algo '1'
	option et_flags 'enable_ipv6 bind_device multi_thread proxy_forward_by_system private_mode'
	option log 'off'
	option multi_thread_count '2'
